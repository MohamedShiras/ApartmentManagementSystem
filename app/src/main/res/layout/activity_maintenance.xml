<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_maintenance"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    tools:context=".MaintenanceActivity">

    <!-- ══════════════════════════════════
         TOP APP BAR
         ══════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EEF4FB"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#214177" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Maintenance"
                android:textColor="#214177"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════
         MAIN SCROLL
         ══════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ SECTION HEADER: Choose a Service ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Choose a Service"
                    android:textColor="#214177"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ══ SERVICE GRID ROW 1 ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp">

                <!-- Plumbing -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/servicePlumbing"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#DBEAFE">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            android:layout_marginBottom="10dp" app:cardCornerRadius="13dp"
                            app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/water_tap_plumber_svgrepo_com"
                                app:tint="#1D4ED8" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Plumbing" android:textColor="#1E293B"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="2dp" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Pipes, taps &amp; drains"
                            android:textColor="#3667A6" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Electrician -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/serviceElectric"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FEF3C7">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            android:layout_marginBottom="10dp" app:cardCornerRadius="13dp"
                            app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/electricity_cable_svgrepo_com"
                                app:tint="#D97706" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Electrician" android:textColor="#1E293B"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="2dp" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Wiring &amp; power"
                            android:textColor="#B45309" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ══ SERVICE GRID ROW 2 ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp">

                <!-- Gas -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/serviceGas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFE4E6">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            android:layout_marginBottom="10dp" app:cardCornerRadius="13dp"
                            app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/gas_cylinder_outline_svgrepo_com"
                                app:tint="#E11D48" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Gas" android:textColor="#1E293B"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="2dp" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Leaks &amp; fittings"
                            android:textColor="#BE123C" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Air Conditioning -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/serviceAC"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#CFFAFE">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            android:layout_marginBottom="10dp" app:cardCornerRadius="13dp"
                            app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/condicioner_svgrepo_com"
                                app:tint="#0891B2" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Air Conditioning" android:textColor="#1E293B"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="2dp" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="AC service &amp; repair"
                            android:textColor="#0E7490" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ══ SERVICE GRID ROW 3 ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp">

                <!-- Carpentry -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/serviceCarpentry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FED7AA">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            android:layout_marginBottom="10dp" app:cardCornerRadius="13dp"
                            app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/carpenter_svgrepo_com"
                                app:tint="#EA580C" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Carpentry" android:textColor="#1E293B"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="2dp" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Doors &amp; furniture"
                            android:textColor="#9A3412" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Cleaning -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/serviceCleaning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#DCFCE7">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            android:layout_marginBottom="10dp" app:cardCornerRadius="13dp"
                            app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_profile"
                                app:tint="#16A34A" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Cleaning" android:textColor="#1E293B"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="2dp" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Deep &amp; common areas"
                            android:textColor="#166534" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ══ SERVICE GRID ROW 4 (empty — reserved) ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="22dp" />

            <!-- ══ MY REQUESTS SECTION HEADER ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Requests"
                    android:textColor="#214177"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all →"
                    android:textColor="#3667A6"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Loading indicator ── -->
            <ProgressBar
                android:id="@+id/requestsLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:visibility="visible" />

            <!-- ── Empty state ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/emptyRequestsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔧"
                        android:textSize="32sp"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No requests yet"
                        android:textColor="#214177"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap a service above to submit your first request"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── DYNAMIC REQUESTS CONTAINER — filled by Java ── -->
            <LinearLayout
                android:id="@+id/requestsDynamicContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>