<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F6FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Profile Section with Notification Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="@drawable/bg_glass_card"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp">
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_admin_avatar_animated"
                    android:background="@drawable/bg_circle_white"
                    android:padding="8dp"
                    android:contentDescription="@string/admin_avatar" />
                <!-- Notification badge -->
                <TextView
                    android:id="@+id/txtNotificationBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|top"
                    android:background="@drawable/bg_circle_red"
                    android:text="@string/notification_count"
                    android:textColor="#fff"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:visibility="visible"
                    android:elevation="4dp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_admin"
                    android:textColor="#214177"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/apartment_management"
                    android:textColor="#6A7D99"
                    android:textSize="13sp" />
            </LinearLayout>
            <!-- Settings icon -->
            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_settings_animated"
                android:contentDescription="@string/settings"
                android:padding="6dp"
                android:background="@drawable/bg_circle_white"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/adminDashboardToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            android:paddingVertical="4dp"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#214177"
            app:title="Admin Dashboard"
            app:titleTextColor="#214177" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/management_modules"
            android:textAllCaps="true"
            android:textColor="#6A7D99"
            android:textSize="12sp" />

        <!-- Reservation Maintenance Card with Ripple and Animated Icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/adminDashboardReservationsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#2A5090"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_reservation_animated"
                    android:background="@drawable/bg_circle_white"
                    android:padding="10dp"
                    android:contentDescription="@string/reservation_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reservation_maintenance"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/reservation_maintenance_desc"
                        android:textColor="#D5E5FF"
                        android:textSize="13sp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="#fff"
                            android:contentDescription="@string/go" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/open_module"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- User Files and Records Card with Ripple and Icon -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:strokeColor="#D4E0EE"
            app:strokeWidth="1dp"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_user_files_animated"
                    android:background="@drawable/bg_circle_blue"
                    android:padding="8dp"
                    android:contentDescription="@string/user_files_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/user_files_and_records"
                        android:textColor="#214177"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/user_files_and_records_desc"
                        android:textColor="#577092"
                        android:textSize="13sp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#214177"
                    android:contentDescription="@string/go" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Example: Add a third module for animation/feature demonstration -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFF7E6"
            app:cardCornerRadius="18dp"
            app:strokeColor="#FFD580"
            app:strokeWidth="1dp"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_analytics_animated"
                    android:background="@drawable/bg_circle_yellow"
                    android:padding="8dp"
                    android:contentDescription="@string/analytics_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analytics_and_reports"
                        android:textColor="#B26A00"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/analytics_and_reports_desc"
                        android:textColor="#B26A00"
                        android:textSize="13sp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#B26A00"
                    android:contentDescription="@string/go" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

