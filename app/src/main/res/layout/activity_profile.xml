<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    tools:context=".ProfileActivity">

    <!-- TOP APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/topBarLogoCard"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#214177"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:id="@+id/avatarInitialsTop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="…"
                    android:textColor="#BDD8F1"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/topBarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="My Profile"
                android:textColor="#214177"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/topBarLogoCard"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- MAIN SCROLL -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Profile Hero Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/profileHeaderCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#214177">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="22dp">

                    <!-- Avatar -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/avatarCard"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#2A5090"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <TextView
                            android:id="@+id/avatarInitials"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="…"
                            android:textColor="#BDD8F1"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <!-- Edit Avatar -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/editAvatarBtn"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        app:cardCornerRadius="13dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:layout_constraintEnd_toEndOf="@id/avatarCard"
                        app:layout_constraintBottom_toBottomOf="@id/avatarCard">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_edit"
                            app:tint="#214177" />
                    </androidx.cardview.widget.CardView>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/residentName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:text="Loading…"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/avatarCard"
                        app:layout_constraintTop_toTopOf="@id/avatarCard"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Unit Badge -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/unitBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="6dp"
                        app:cardCornerRadius="13dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#2A5090"
                        app:layout_constraintStart_toEndOf="@id/avatarCard"
                        app:layout_constraintTop_toBottomOf="@id/residentName">
                        <TextView
                            android:id="@+id/residentUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="—"
                            android:textColor="#BDD8F1"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <!-- Member Since -->
                    <TextView
                        android:id="@+id/memberSince"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="6dp"
                        android:text="—"
                        android:textColor="#82A6CB"
                        android:textSize="12sp"
                        app:layout_constraintStart_toEndOf="@id/avatarCard"
                        app:layout_constraintTop_toBottomOf="@id/unitBadge"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Stats Row -->
                    <LinearLayout
                        android:id="@+id/statsRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="24dp"
                        android:background="#2A5090"
                        android:padding="16dp"
                        app:layout_constraintTop_toBottomOf="@id/avatarCard"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView
                                android:id="@+id/statPosts"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Posts" android:textColor="#BDD8F1" android:textSize="11sp" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="30dp"
                            android:background="#FFFFFF" android:alpha="0.1" />

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView
                                android:id="@+id/statRequests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Requests" android:textColor="#BDD8F1" android:textSize="11sp" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="30dp"
                            android:background="#FFFFFF" android:alpha="0.1" />

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView
                                android:id="@+id/statTenure"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Tenure" android:textColor="#BDD8F1" android:textSize="11sp" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Personal Information ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="10dp"
                android:text="Personal Information"
                android:textColor="#214177"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/personalInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="6dp">

                    <!-- Phone -->
                    <LinearLayout android:id="@+id/rowPhone" android:layout_width="match_parent"
                        android:layout_height="60dp" android:orientation="horizontal"
                        android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                        <androidx.cardview.widget.CardView android:layout_width="38dp" android:layout_height="38dp"
                            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#EEF4FB">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                                android:layout_gravity="center" android:src="@drawable/ic_phone" app:tint="#3667A6" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Phone" android:textColor="#94A3B8" android:textSize="11sp" />
                            <TextView android:id="@+id/phoneValue" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textColor="#1E293B" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right" app:tint="#CBD5E1" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginStart="64dp" />

                    <!-- Email -->
                    <LinearLayout android:id="@+id/rowEmail" android:layout_width="match_parent"
                        android:layout_height="60dp" android:orientation="horizontal"
                        android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                        <androidx.cardview.widget.CardView android:layout_width="38dp" android:layout_height="38dp"
                            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#EEF4FB">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                                android:layout_gravity="center" android:src="@drawable/ic_email" app:tint="#3667A6" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Email" android:textColor="#94A3B8" android:textSize="11sp" />
                            <TextView android:id="@+id/emailValue" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textColor="#1E293B" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right" app:tint="#CBD5E1" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Lease & Rent ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="10dp"
                android:text="Lease &amp; Rent"
                android:textColor="#214177"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/leaseCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="6dp">

                    <!-- Lease Expiry -->
                    <LinearLayout android:id="@+id/rowLease" android:layout_width="match_parent"
                        android:layout_height="60dp" android:orientation="horizontal"
                        android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                        <androidx.cardview.widget.CardView android:layout_width="38dp" android:layout_height="38dp"
                            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#EDE9FE">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                                android:layout_gravity="center" android:src="@drawable/ic_calendar" app:tint="#7C3AED" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Lease Expiry" android:textColor="#94A3B8" android:textSize="11sp" />
                            <TextView android:id="@+id/leaseExpiryValue" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textColor="#1E293B" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                        <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="22dp"
                            app:cardCornerRadius="11dp" app:cardElevation="0dp" app:cardBackgroundColor="#DCFCE7">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:text="Active" android:textColor="#16A34A" android:textSize="10sp" android:textStyle="bold" />
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginStart="64dp" />

                    <!-- Rent Due -->
                    <LinearLayout android:id="@+id/rowRent" android:layout_width="match_parent"
                        android:layout_height="60dp" android:orientation="horizontal"
                        android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                        <androidx.cardview.widget.CardView android:layout_width="38dp" android:layout_height="38dp"
                            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#EEF4FB">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                                android:layout_gravity="center" android:src="@drawable/ic_payment" app:tint="#3667A6" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Next Rent Due" android:textColor="#94A3B8" android:textSize="11sp" />
                            <TextView android:id="@+id/rentDueValue" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textColor="#1E293B" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right" app:tint="#CBD5E1" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Account Settings ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="10dp"
                android:text="Account Settings"
                android:textColor="#214177"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/accountCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="6dp">

                    <!-- Change Password -->
                    <LinearLayout android:id="@+id/rowChangePassword" android:layout_width="match_parent"
                        android:layout_height="60dp" android:orientation="horizontal"
                        android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                        <androidx.cardview.widget.CardView android:layout_width="38dp" android:layout_height="38dp"
                            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#F1F5F9">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                                android:layout_gravity="center" android:src="@drawable/ic_lock" app:tint="#64748B" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="14dp"
                            android:text="Change Password" android:textColor="#1E293B"
                            android:textSize="14sp" android:textStyle="bold" />
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right" app:tint="#CBD5E1" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginStart="64dp" />

                    <!-- Push Notifications -->
                    <LinearLayout android:id="@+id/rowNotifications" android:layout_width="match_parent"
                        android:layout_height="60dp" android:orientation="horizontal"
                        android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                        <androidx.cardview.widget.CardView android:layout_width="38dp" android:layout_height="38dp"
                            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#F1F5F9">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                                android:layout_gravity="center" android:src="@drawable/ic_notifications" app:tint="#64748B" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="14dp"
                            android:text="Push Notifications" android:textColor="#1E293B"
                            android:textSize="14sp" android:textStyle="bold" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/notificationsSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="#214177"
                            app:trackTint="#CBD5E1" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginStart="64dp" />

                    <!-- Help -->
                    <LinearLayout android:id="@+id/rowHelp" android:layout_width="match_parent"
                        android:layout_height="60dp" android:orientation="horizontal"
                        android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                        <androidx.cardview.widget.CardView android:layout_width="38dp" android:layout_height="38dp"
                            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#F1F5F9">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                                android:layout_gravity="center" android:src="@drawable/ic_help" app:tint="#64748B" />
                        </androidx.cardview.widget.CardView>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="14dp"
                            android:text="Help &amp; Support" android:textColor="#1E293B"
                            android:textSize="14sp" android:textStyle="bold" />
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right" app:tint="#CBD5E1" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Sign Out Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:text="Sign Out"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="#EF4444"
                app:cornerRadius="28dp"
                app:elevation="4dp"
                app:icon="@drawable/ic_logout"
                app:iconTint="#FFFFFF"
                app:iconGravity="textStart" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <RelativeLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_alignParentBottom="true"
            android:background="#FFFFFF"
            android:elevation="8dp"
            android:orientation="horizontal">

            <LinearLayout android:id="@+id/nav_btn_notices" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1" android:gravity="center"
                android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/nav_icon_notices" android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_announcement" app:tint="#9E9E9E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Notices" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_btn_chat" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1" android:gravity="center"
                android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/nav_icon_chat" android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_chat" app:tint="#9E9E9E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Chat" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="3dp" />
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

            <LinearLayout android:id="@+id/nav_btn_services" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1" android:gravity="center"
                android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/nav_icon_services" android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_services" app:tint="#9E9E9E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Services" android:textSize="10sp" android:textColor="#9E9E9E" android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_btn_profile" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1" android:gravity="center"
                android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/nav_icon_profile" android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_profile" app:tint="#214177" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Profile" android:textSize="10sp" android:textColor="#214177" android:layout_marginTop="3dp" />
            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/nav_btn_feed"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true"
            android:elevation="12dp"
            android:clickable="true"
            android:focusable="true">
            <View android:layout_width="46dp" android:layout_height="46dp"
                android:layout_gravity="center" android:rotation="45"
                android:background="@drawable/bg_fab_diamond" />
            <ImageView android:id="@+id/nav_icon_feed" android:layout_width="24dp" android:layout_height="24dp"
                android:layout_gravity="center" android:src="@drawable/ic_feed" app:tint="#FFFFFF" />
        </FrameLayout>

    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>