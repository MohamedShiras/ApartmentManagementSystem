<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    android:layout_margin="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pay Your Rent"
            android:textColor="#214177"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verify details and complete payment"
            android:textSize="13sp"
            android:textColor="#64748b"
            android:layout_marginBottom="20dp"/>

        <!-- User Info Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F8FAFC"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvUserDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resident: Loading..."
                android:textColor="#1e293b"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvUserDetailUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unit: --"
                android:textColor="#475569"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvAmountDue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LKR 0.00"
                android:textColor="#DC2626"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card Input Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Card Information"
            android:textStyle="bold"
            android:textColor="#1e293b"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"/>

        <!-- Card Number — gray background + rounded corners -->
        <EditText
            android:id="@+id/etCardNum"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="0000 0000 0000 0000"
            android:textColorHint="#535454"
            android:textColor="#1e293b"
            android:inputType="number"
            android:maxLength="19"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_gray_bg"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Expiry — gray background + rounded corners -->
            <EditText
                android:id="@+id/etExp"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:hint="MM/YY"
                android:inputType="number"
                android:textColorHint="#535454"
                android:textColor="#1e293b"
                android:maxLength="5"
                android:layout_marginEnd="6dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/input_gray_bg"/>

            <!-- CVC — gray background + rounded corners -->
            <EditText
                android:id="@+id/etCvc"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:textColorHint="#535454"
                android:textColor="#1e293b"
                android:hint="CVC"
                android:inputType="numberPassword"
                android:maxLength="3"
                android:layout_marginStart="6dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/input_gray_bg"/>
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="30dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textAllCaps="false"
                android:backgroundTint="#f1f5f9"
                android:textColor="#64748b"
                app:cornerRadius="28dp"
                android:layout_marginEnd="10dp"/>

            <Button
                android:id="@+id/btnFinalizePayment"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="Pay Now"
                android:textAllCaps="false"
                android:backgroundTint="#214177"
                android:textColor="#FFFFFF"
                app:cornerRadius="28dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>