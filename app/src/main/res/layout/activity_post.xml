<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_post"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF"
    tools:context=".PostActivity">

  <!-- TOP BAR -->
  <androidx.cardview.widget.CardView
      android:id="@+id/topBarCard"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      app:cardBackgroundColor="#FFFFFF"
      app:cardCornerRadius="0dp"
      app:cardElevation="3dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

      <ImageButton
          android:id="@+id/btnBack"
          android:layout_width="44dp"
          android:layout_height="44dp"
          android:background="?attr/selectableItemBackgroundBorderless"
          android:src="@drawable/ic_arrow_back"
          app:tint="#0D47A1" />

      <FrameLayout
          android:layout_width="38dp"
          android:layout_height="38dp"
          android:layout_marginStart="4dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgUserAvatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="#3667A6"
            app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full" />

        <TextView
            android:id="@+id/tvAvatarInitials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="AJ"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
      </FrameLayout>

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="10dp"
          android:layout_weight="1"
          android:orientation="vertical">

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Alex Johnson"
            android:textColor="#0D1B3E"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvUserUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unit 4B · Block C"
            android:textColor="#6B7A99"
            android:textSize="11sp" />
      </LinearLayout>

      <com.google.android.material.button.MaterialButton
          android:id="@+id/btnPost"
          android:layout_width="wrap_content"
          android:layout_height="44dp"
          android:backgroundTint="#3667A6"
          android:paddingStart="18dp"
          android:paddingEnd="18dp"
          android:text="Post"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          android:textStyle="bold"
          app:cornerRadius="18dp"
          app:icon="@drawable/ic_send"
          app:iconGravity="end"
          app:iconSize="15dp" />
    </LinearLayout>
  </androidx.cardview.widget.CardView>

  <View
      android:id="@+id/dividerTop"
      android:layout_width="0dp"
      android:layout_height="1dp"
      android:background="#E8ECF4"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/topBarCard" />

  <!-- SCROLLABLE WRITE AREA -->
  <androidx.core.widget.NestedScrollView
      android:id="@+id/scrollContent"
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:fillViewport="true"
      app:layout_constraintBottom_toTopOf="@id/bottomBar"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/dividerTop">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

      <!-- WRITE CARD -->
      <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginStart="12dp"
          android:layout_marginTop="12dp"
          android:layout_marginEnd="12dp"
          app:cardBackgroundColor="#FFFFFF"
          app:cardCornerRadius="16dp"
          app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:minHeight="400dp"
            android:orientation="vertical"
            android:padding="16dp">

          <!-- Text input -->

          <!-- IMAGE PREVIEW — GONE until image selected -->
          <EditText
              android:id="@+id/etCaption"
              android:layout_width="match_parent"
              android:layout_height="207dp"
              android:background="@android:color/transparent"
              android:fontFamily="sans-serif"
              android:gravity="top|start"
              android:hint="What's on your mind? Share with your community..."
              android:inputType="textMultiLine|textCapSentences"
              android:minHeight="120dp"
              android:padding="0dp"
              android:textColor="#0D1B3E"
              android:textColorHint="#A0AABF"
              android:textSize="15sp" />

          <FrameLayout
              android:id="@+id/frameImagePreview"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="14dp"
              android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

              <ImageView
                  android:id="@+id/imgMediaPreview"
                  android:layout_width="match_parent"
                  android:layout_height="220dp"
                  android:background="#E8EEFF"
                  android:scaleType="centerCrop" />

            </androidx.cardview.widget.CardView>

            <!-- Video play overlay -->
            <ImageView
                android:id="@+id/ivPlayOverlay"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_circle"
                android:visibility="gone"
                app:tint="@android:color/white" />

            <!-- Remove button -->
            <ImageButton
                android:id="@+id/btnRemoveMedia"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/circle_dark_bg"
                android:contentDescription="Remove media"
                android:src="@drawable/ic_close"
                app:tint="@android:color/white" />

          </FrameLayout>

          <!-- Char count -->

          <!-- Divider -->

          <TextView
              android:id="@+id/tvCharCount"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="8dp"
              android:gravity="end"
              android:text="0 / 500"
              android:textColor="#C0C8DC"
              android:textSize="11sp" />

          <View
              android:layout_width="match_parent"
              android:layout_height="1dp"
              android:layout_marginTop="10dp"
              android:background="#E8ECF4" />

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="78dp"
              android:layout_marginTop="10dp"
              android:gravity="center_vertical"
              android:orientation="horizontal">

            <!-- Photo pill button -->
            <LinearLayout
                android:id="@+id/optionPhoto"
                android:layout_width="106dp"
                android:layout_height="49dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="14dp">

              <ImageView
                  android:layout_width="43dp"
                  android:layout_height="30dp"
                  android:src="@drawable/ic_photo"
                  app:tint="#3667A6" />

              <com.google.android.material.button.MaterialButton
                  android:id="@+id/btnAddMore"
                  style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                  android:layout_width="wrap_content"
                  android:layout_height="36dp"
                  android:layout_marginStart="8dp"
                  android:minWidth="0dp"
                  android:minHeight="0dp"
                  android:padding="0dp"
                  app:cornerRadius="10dp"
                  app:icon="@drawable/ic_add"
                  app:iconSize="30dp"
                  app:iconTint="#3667A6"
                  app:strokeColor="#ffffff"
                  app:strokeWidth="1.5dp" />


            </LinearLayout>

            <!-- + button -->

          </LinearLayout>

        </LinearLayout>


      </androidx.cardview.widget.CardView>

      <View
          android:layout_width="match_parent"
          android:layout_height="17dp" />

    </LinearLayout>
  </androidx.core.widget.NestedScrollView>

  <!-- BOTTOM BAR -->
  <androidx.cardview.widget.CardView
      android:id="@+id/bottomBar"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      app:cardBackgroundColor="#FFFFFF"
      app:cardCornerRadius="0dp"
      app:cardElevation="12dp"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

      <View
          android:layout_width="match_parent"
          android:layout_height="1dp"
          android:background="#E8ECF4" />


    </LinearLayout>
  </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>