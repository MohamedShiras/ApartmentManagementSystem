<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dialogServiceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plumbing"
                    android:textColor="#214177"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialogServiceSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pipes, taps &amp; drains"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Status pill -->
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                app:cardCornerRadius="13dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EEF4FB">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="New Request"
                    android:textColor="#214177"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginBottom="20dp" />

        <!-- ── Issue Type Dropdown ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Issue Type"
            android:textColor="#214177"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#BDD8F1"
            app:hintTextColor="#3667A6">

            <AutoCompleteTextView
                android:id="@+id/issueDropdown"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="none"
                android:paddingStart="16dp"
                android:textColor="#1E293B"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Description ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="#214177"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#BDD8F1"
            app:hintTextColor="#3667A6"
            android:hint="Describe the issue in detail…">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:textColor="#1E293B"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Priority Dropdown ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priority"
            android:textColor="#214177"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#BDD8F1"
            app:hintTextColor="#3667A6">

            <AutoCompleteTextView
                android:id="@+id/priorityDropdown"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="none"
                android:paddingStart="16dp"
                android:textColor="#1E293B"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Note ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EEF4FB">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Our team will review your request and contact you within 24 hours."
                    android:textColor="#3667A6"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelRequest"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Cancel"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:textAllCaps="false"
                app:backgroundTint="#F1F5F9"
                app:cornerRadius="26dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitRequest"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Submit"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="false"
                app:backgroundTint="#214177"
                app:cornerRadius="26dp"
                app:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
