<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp"
    android:gravity="bottom">

    <!-- Avatar circle with initials -->
    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_avatar_received"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:text="?"
        android:layout_marginEnd="8dp"/>

    <!-- Column: sender name + bubble + reaction -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Sender name -->
        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#455A64"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="3dp"
            android:layout_marginStart="4dp"/>

        <!-- White bubble (left-aligned) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_received"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:maxWidth="260dp">

            <!-- Reply preview strip (hidden by default) -->
            <LinearLayout
                android:id="@+id/layoutReplyPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1A1565C0"
                android:padding="8dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="#1565C0"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvReplyPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1565C0"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Message text -->
            <TextView
                android:id="@+id/tvMessageContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1C1C1C"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.2"/>

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvMessageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>


    </LinearLayout>

    <!-- Right spacer so bubble doesn't go full width -->
    <View android:layout_width="48dp" android:layout_height="1dp"/>

</LinearLayout>