<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F6FB">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/adminBookingToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2A5090"
        android:elevation="4dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="#FFFFFF"
        app:title="User Bookings"
        app:titleTextColor="#FFFFFF" />

    <!-- Loading Text -->
    <TextView
        android:id="@+id/adminBookingLoadingText"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Loading bookings..."
        android:textColor="#2A5090"
        android:textSize="16sp"
        android:visibility="visible" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/adminBookingEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_pool"
            android:tint="#5E7EA6"
            android:contentDescription="@string/empty_state" />

        <TextView
            android:id="@+id/adminBookingEmptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No bookings yet"
            android:textColor="#2A5090"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User bookings will appear here"
            android:textColor="#5E7EA6"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/adminBookingRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:visibility="gone" />

</LinearLayout>

